{
  "permissions": {
    "allow": [
      "Bash(gh pr:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue status:*)",
      "Bash(gh issue view:*)",
      "Bash(gh label:*)",
      "Bash(echo \"exit: $?\")"
    ],
    "deny": [
      "Bash(gh pr merge:*)"
    ],
  }
}
