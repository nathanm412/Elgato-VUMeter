{
  "name": "com.nathanm412.vumeter",
  "version": "1.1.0",
  "description": "Real-time stereo VU meter for Elgato Stream Deck Plus with gradient key fills and touch display support",
  "main": "com.nathanm412.vumeter.sdPlugin/bin/plugin.js",
  "scripts": {
    "build": "rollup -c && node scripts/copy-assets.js",
    "watch": "tsc --watch",
    "pack": "npm run build && node scripts/pack.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf com.nathanm412.vumeter.sdPlugin/bin",
    "dev": "npm run build && streamdeck dev",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "prepare": "npm run build",
    "release": "node scripts/release.js"
  },
  "keywords": [
    "stream-deck",
    "elgato",
    "vu-meter",
    "audio",
    "visualization",
    "stream-deck-plus"
  ],
  "author": "nathanm412",
  "license": "MIT",
  "devDependencies": {
    "@elgato/cli": "1.7.3",
    "@eslint/js": "10.0.1",
    "@rollup/plugin-commonjs": "29.0.2",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-typescript": "12.3.0",
    "@tsconfig/node24": "24.0.4",
    "@types/jest": "30.0.0",
    "@types/node": "24.12.2",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "archiver": "7.0.1",
    "eslint": "10.2.0",
    "jest": "30.3.0",
    "rollup": "4.60.1",
    "ts-jest": "29.4.9",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.1"
  },
  "dependencies": {
    "@elgato-stream-deck/node": "^7.6.2",
    "@elgato/streamdeck": "^2.0.4"
  }
}
